# Workshop deployment config — deploy fvmw directly into the workshop cluster.
# Copy to workshop-deploy.env and fill in your values.
#
# Usage:
#   cp workshop-deploy.env.example workshop-deploy.env
#   vi workshop-deploy.env
#   cd deploy/ansible && ansible-playbook build.yml -e @../../workshop-deploy.env
#   cd deploy/ansible && ansible-playbook deploy.yml -e @../../workshop-deploy.env

# Kubeconfig with cluster-admin access to the workshop cluster
k8s_kubeconfig: ~/secrets/workshop-cluster.kubeconfig

# Workshop cluster apps domain
cluster_domain: apps.cluster-xxxxx.dynamic.redhatworkshops.io

# Namespace for fvmw pods
fvmw_namespace: fvmw

# Container image (built by build.yml into the internal registry)
fvmw_image: image-registry.openshift-image-registry.svc:5000/fvmw/fvmw:latest

# vSphere password (used by MTV provider and demo users)
fvmw_password: changeme

# GitHub token (needed for private repo builds)
# github_token: "{{ lookup('pipe', 'gh auth token') }}"

# Storage class for shared VMDK PVC (must support ReadWriteMany)
storage_class: ocs-external-storagecluster-cephfs

# URL of the disk server hosting flat VMDKs
# Deploy disk-server.yml on your infra cluster first
# disk_source_url: https://fvmw-disks.apps.<infra-cluster-domain>

# Users to provision (each gets a vcenter + esxi pod pair)
fvmw_users:
  - user1
  - user2
  - user3

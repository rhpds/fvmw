# Copy this file to local.env and fill in your values.
# local.env is gitignored and will not be committed.
#
# Usage:
#   cp local.env.example local.env
#   vi local.env
#   cd deploy/ansible && ansible-playbook deploy.yml -e @../../local.env

# Kubeconfig for OCP access (generated by bootstrap.yml)
# k8s_kubeconfig: ~/secrets/fvmw-mgmt.kubeconfig

# OCP cluster apps domain (e.g. apps.cluster.example.com)
cluster_domain: apps.cluster.example.com

# Namespace to deploy into
fvmw_namespace: fvmw

# Container image (use internal registry after build.yml)
fvmw_image: image-registry.openshift-image-registry.svc:5000/fvmw/fvmw:latest

# vSphere admin password for all fvmw instances
fvmw_password: changeme

# GitHub token for private repo access (build.yml) and webhook setup (setup-webhook.yml)
# Can use: github_token: "{{ lookup('pipe', 'gh auth token') }}"
# github_token: ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# List of users to provision (each gets a vcenter + esxi pod pair)
fvmw_users:
  - user1
  - user2

# Shared PVC storage class (must support ReadWriteMany, e.g. CephFS)
# storage_class: ocs-storagecluster-cephfs

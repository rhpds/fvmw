# Infra cluster config — for disk-server.yml and individual playbooks.
# Copy to local.env and fill in your values. Gitignored.
#
# Usage:
#   cp local.env.example local.env
#   vi local.env
#   cd deploy/ansible && ansible-playbook disk-server.yml -e @../../local.env

# Kubeconfig with cluster-admin access to the infra cluster
# k8s_kubeconfig: ~/secrets/fvmw-mgmt.kubeconfig

# Infra cluster apps domain
cluster_domain: apps.cluster.example.com

# Namespace for fvmw resources
fvmw_namespace: fvmw

# Shared PVC storage class (must support ReadWriteMany, e.g. CephFS)
# storage_class: ocs-storagecluster-cephfs

# Source vCenter for VMDK export (used by disk-server.yml)
source_vcenter_url: https://vcenter.example.com/sdk
source_vcenter_user: Administrator@vsphere.local
source_vcenter_password: changeme

# --- Below only needed for individual playbooks (not disk-server.yml) ---

# Container image (use internal registry after build.yml)
fvmw_image: image-registry.openshift-image-registry.svc:5000/fvmw/fvmw:latest

# vSphere admin password for fvmw instances
fvmw_password: changeme

# GitHub token for private repo access
# github_token: "{{ lookup('pipe', 'gh auth token') }}"

# Users to provision
fvmw_users:
  - user1
  - user2
